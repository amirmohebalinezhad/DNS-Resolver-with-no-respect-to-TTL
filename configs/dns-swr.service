[Unit]
Description=DNS-SWR forwarding resolver
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dns-swr
Group=dns-swr
ExecStart=/usr/local/bin/dns-swr -config /etc/dns-swr/config.yaml
Restart=on-failure
RestartSec=5s
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
